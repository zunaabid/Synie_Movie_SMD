<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_book_now"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Movie Header Image -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:background="@drawable/bg_movie_placeholder">

                <ImageButton
                    android:id="@+id/btn_back_details"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_social_button"
                    android:src="@drawable/ic_back"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btn_favorite"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_social_button"
                    android:src="@drawable/ic_heart"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btn_play_trailer"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_social_button"
                    android:src="@drawable/ic_play"
                    android:padding="16dp"

                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Biography • PG-13 • 1h 56m"
                        android:textColor="@color/gray_text"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Oppenheimer"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_selected"
                            android:paddingHorizontal="4dp"
                            android:text="+13"
                            android:textColor="@color/white"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_chip"
                            android:paddingHorizontal="4dp"
                            android:text="EN"
                            android:textColor="@color/gray_text"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_chip"
                            android:paddingHorizontal="4dp"
                            android:text="Sub EN/SP"
                            android:textColor="@color/gray_text"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Ratings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8.9/10" android:textColor="@color/white" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IMDB" android:textColor="@color/gray_text" android:textSize="10sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/divider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="96%" android:textColor="@color/white" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rotten Tomatoes" android:textColor="@color/gray_text" android:textSize="10sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/divider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9.5/10" android:textColor="@color/white" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CornPass" android:textColor="@color/gray_text" android:textSize="10sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Synopsis -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:text="During World War II, Lt. Gen. Leslie Groves Jr. appoints physicist J. Robert Oppenheimer to work on the top-secret Manhattan Project. Oppenheimer and a team of scientists spend years developing and See More.."
                android:textColor="@color/gray_text"
                android:textSize="14sp" />

            <!-- Media/Trailers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_movie_placeholder">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play"
                        app:tint="@color/white" />
                </FrameLayout>

                <View
                    android:layout_width="160dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_movie_placeholder" />

            </LinearLayout>

            <!-- Cast/Crew -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Director" android:textColor="@color/gray_text" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Christopher Nolan" android:textColor="@color/white" android:textStyle="bold" />

                <View android:layout_width="match_parent" android:layout_height="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Writers" android:textColor="@color/gray_text" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Christopher Nolan\nKai Bird\nMartin Sherwin" android:textColor="@color/white" android:textStyle="bold" />

                <View android:layout_width="match_parent" android:layout_height="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stars" android:textColor="@color/gray_text" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cillian Murphy\nEmily Blunt" android:textColor="@color/white" android:textStyle="bold" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btn_book_now"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:backgroundTint="@color/primary"
        android:text="Book Tickets"
        android:textAllCaps="false"
        android:textColor="@color/onPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
