<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header Section (Gray) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/seat_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#333333"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back_seat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_social_button"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_favorite_seat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_social_button"
            android:src="@drawable/ic_heart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_seat_movie_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="Oppenheimer"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/labels_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_seat_movie_title">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_selected"
                android:paddingHorizontal="4dp"
                android:text="+13"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="4dp"
                android:text="EN"
                android:textColor="@color/gray_text"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="4dp"
                android:text="ScreenX"
                android:textColor="@color/gray_text"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Info Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/labels_container">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:drawableStart="@drawable/ic_location" android:drawablePadding="4dp" android:drawableTint="@color/gray_text" android:text="Theater" android:textColor="@color/gray_text" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stars (90°Mall)" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:drawableStart="@drawable/ic_menu" android:drawablePadding="4dp" android:drawableTint="@color/gray_text" android:text="Hall" android:textColor="@color/gray_text" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1st" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:drawableStart="@drawable/ic_calendar" android:drawablePadding="4dp" android:drawableTint="@color/gray_text" android:text="Date" android:textColor="@color/gray_text" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13.04.2025" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:drawableStart="@drawable/ic_time" android:drawablePadding="4dp" android:drawableTint="@color/gray_text" android:text="Time" android:textColor="@color/gray_text" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="22:15" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Seat Map Section -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/legend_container"
        app:layout_constraintTop_toBottomOf="@id/seat_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Screen Curve Placeholder -->
            <View
                android:layout_width="200dp"
                android:layout_height="4dp"
                android:background="@color/seat_selected"
                android:layout_marginBottom="32dp" />

            <!-- Simple Seat Grid (UI Placeholder) -->
            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="9"
                android:useDefaultMargins="true">

                <!-- Row 1 -->
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:visibility="invisible" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />

                <!-- Row 2 (with booked) -->
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_booked" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:visibility="invisible" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_booked" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />

                <!-- Row 3 (with selected) -->
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:visibility="invisible" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_selected" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_selected" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_selected" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />
                <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_seat_available" />

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Legend -->
    <LinearLayout
        android:id="@+id/legend_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_proceed_cashout">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_seat_booked" android:backgroundTint="@color/gray_text" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Booked" android:textColor="@color/white" android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_seat_selected" android:backgroundTint="@color/accent_yellow" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Yours" android:textColor="@color/white" android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_seat_available" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Available" android:textColor="@color/white" android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btn_proceed_cashout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:backgroundTint="@color/primary"
        android:text="Proceed to Cash Out"
        android:textAllCaps="false"
        android:textColor="@color/onPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
